# NestJS API — Environment Variables
# Copy this to .env and fill in values from your Supabase project dashboard

# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (Settings → API → service_role secret)
# WARNING: Never expose this on the client. Backend only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase JWT secret (Settings → API → JWT Settings → JWT Secret)
# Used to verify tokens offline without a round-trip to Supabase
SUPABASE_JWT_SECRET=your-jwt-secret-here

# URL of the Next.js frontend (for CORS allowlist)
FRONTEND_URL=http://localhost:3000

# Port the NestJS server will listen on
PORT=3001

# Groq API key — get one free at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
